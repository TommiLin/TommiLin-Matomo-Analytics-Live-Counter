<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="5.0" client="site" method="upgrade">
    <name>MOD_MATOMO_COUNTER_NAME</name>
    <author>TommiLin</author>
    <creationDate>June 2026</creationDate>
    <copyright>Copyright (C) 2026 TommiLin. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>tomilinsergeialex@gmail.com</authorEmail>
    <authorUrl>https://github.com/TommiLin</authorUrl>
    <version>1.2.2</version>
    <description>MOD_MATOMO_COUNTER_DESCRIPTION</description>
    <namespace path="src">TommiLin\Module\MatomoCounter</namespace>
    <scriptfile>script.php</scriptfile>
    
    <updateservers>
    <server type="extension" priority="1">
        https://raw.githubusercontent.com/TommiLin/TommiLin-Matomo-Analytics-Live-Counter/main/updates.xml
    </server>
    </updateservers>
    
    <files>
        <filename module="mod_matomo_counter">mod_matomo_counter.php</filename>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>

    <config>
        <fields name="params">
            <fieldset name="basic" label="COM_MODULES_BASIC_FIELDSET_LABEL">
                <field name="matomo_url" type="url" default="" label="MOD_MATOMO_COUNTER_FIELD_URL_LABEL" description="MOD_MATOMO_COUNTER_FIELD_URL_DESC" required="true" filter="string" />
                <field name="site_id" type="number" default="1" label="MOD_MATOMO_COUNTER_FIELD_SITEID_LABEL" required="true" />
                <field name="token_auth" type="text" default="" label="MOD_MATOMO_COUNTER_FIELD_TOKEN_LABEL" description="MOD_MATOMO_COUNTER_FIELD_TOKEN_DESC" required="true" filter="string" />
                <field name="cache_time" type="number" default="300" label="MOD_MATOMO_COUNTER_FIELD_CACHE_LABEL" required="true" />
                <field name="force_language" type="list" default="site" label="MOD_MATOMO_COUNTER_FIELD_FORCE_LANG_LABEL" description="MOD_MATOMO_COUNTER_FIELD_FORCE_LANG_DESC">
                    <option value="site">MOD_MATOMO_COUNTER_LANG_AUTO</option>
                    <option value="uk-UA">Ukrainian (uk-UA)</option>
                    <option value="ru-RU">Russian (ru-RU)</option>
                    <option value="en-GB">English (en-GB)</option>
                </field>
                <field 
                    name="debug_mode" 
                    type="list" 
                    default="super" 
                    label="MOD_MATOMO_COUNTER_DEBUG" 
                    description="Select who can see the API request logging at the bottom of the module.">
                    <option value="0">JDISABLED</option>
                    <option value="super">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                    <option value="1">JSHOW</option>
                </field>
            </fieldset>

            <fieldset name="display" label="MOD_MATOMO_COUNTER_FIELDSET_DISPLAY">
                <field name="show_online" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_ONLINE">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_today" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_TODAY">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_today_views" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_TODAY_VIEWS">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_yesterday" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_YESTERDAY">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_week" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_WEEK">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_month" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_MONTH">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_countries" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_COUNTRIES">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_top_countries" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_TOP_COUNTRIES">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
                <field name="show_chart" type="list" default="1" label="MOD_MATOMO_COUNTER_METRIC_CHART">
                    <option value="1">JSHOW</option>
                    <option value="0">JHIDE</option>
                    <option value="2">MOD_MATOMO_COUNTER_OPTION_ADMINS</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>