<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="5.0" client="site" method="upgrade">
    <name>MOD_MATOMO_COUNTER_NAME</name>
    <author>Tomilin Serhii</author>
    <creationDate>June 2026</creationDate>
    <copyright>Copyright (C) 2026 Tomilin Serhii. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <authorEmail>tomilinsergeialex@gmail.com</authorEmail>
    <version>1.0.1</version>
    <description>MOD_MATOMO_COUNTER_DESCRIPTION</description>
    
    <updateservers>
    <server type="extension" priority="1">
        https://raw.githubusercontent.com/TommiLin/Matomo-Analytics-Live-Counter/main/updates.xml
    </server>
</updateservers>
    
    <files>
        <filename module="mod_matomo_counter">mod_matomo_counter.php</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
        <folder>src</folder>
    </files>
    
    <languages folder="language">
        <language folder="en-GB">en-GB/mod_matomo_counter.ini</language>
        <language folder="en-GB">en-GB/mod_matomo_counter.sys.ini</language>
        <language folder="ru-RU">ru-RU/mod_matomo_counter.ini</language>
        <language folder="ru-RU">ru-RU/mod_matomo_counter.sys.ini</language>
        <language folder="uk-UA">uk-UA/mod_matomo_counter.ini</language>
        <language folder="uk-UA">uk-UA/mod_matomo_counter.sys.ini</language>
    </languages>
    
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="matomo_url" type="url" label="MOD_MATOMO_COUNTER_FIELD_URL_LABEL" description="MOD_MATOMO_COUNTER_FIELD_URL_DESC" required="true" />
                <field name="site_id" type="number" label="MOD_MATOMO_COUNTER_FIELD_SITEID_LABEL" default="1" required="true" />
                <field name="token_auth" type="text" label="MOD_MATOMO_COUNTER_FIELD_TOKEN_LABEL" description="MOD_MATOMO_COUNTER_FIELD_TOKEN_DESC" required="true" />
                <field name="cache_time" type="number" label="MOD_MATOMO_COUNTER_FIELD_CACHE_LABEL" default="300" required="true" />
                <field name="force_language" type="list" label="MOD_MATOMO_COUNTER_FIELD_FORCE_LANG_LABEL" description="MOD_MATOMO_COUNTER_FIELD_FORCE_LANG_DESC" default="site">
                    <option value="site">MOD_MATOMO_COUNTER_LANG_AUTO</option>
                    <option value="ru-RU">Русский (ru-RU)</option>
                    <option value="uk-UA">Українська (uk-UA)</option>
                    <option value="en-GB">English (en-GB)</option>
                </field>
            </fieldset>
            
            <fieldset name="display" label="MOD_MATOMO_COUNTER_FIELDSET_DISPLAY">
                <field name="show_online" type="radio" label="MOD_MATOMO_COUNTER_METRIC_ONLINE" default="1" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="show_today" type="radio" label="MOD_MATOMO_COUNTER_METRIC_TODAY" default="1" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="show_today_views" type="radio" label="MOD_MATOMO_COUNTER_METRIC_TODAY_VIEWS" default="0" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="show_week" type="radio" label="MOD_MATOMO_COUNTER_METRIC_WEEK" default="1" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field name="show_month" type="radio" label="MOD_MATOMO_COUNTER_METRIC_MONTH" default="0" class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
